# mosta-parkmanager — variables d'environnement
# Auteur : Dr Hamid MADANI <drmdh@msn.com>
#
# Copier ce fichier vers .env.local puis remplir les valeurs.
#   cp .env.example .env.local
#
# La cascade @mostajs/config lit en priorité :
#   1. process.env (déjà défini)
#   2. .env.${MOSTA_ENV}.local       (ex: .env.dev.local)
#   3. .env.${MOSTA_ENV}             (ex: .env.dev)
#   4. .env.local
#   5. .env

# ── Mode d'environnement (optionnel) ───────────────────────────
# MOSTA_ENV=dev

# ── Bootstrap @mostajs/orm + data-plug ─────────────────────────
# Dialect SGBD : sqlite | postgres | mysql | mariadb | oracle | mongodb
DB_DIALECT=sqlite

# URI selon le dialect :
#   sqlite   : chemin fichier (./data/parkmanager.db)
#   postgres : postgres://user:pass@host:5432/dbname
#   mysql    : mysql://user:pass@host:3306/dbname
#   mariadb  : mariadb://user:pass@host:3306/dbname
#   oracle   : oracle://user:pass@host:1521/SERVICE
#   mongodb  : mongodb://user:pass@host:27017/dbname
SGBD_URI=./data/parkmanager.db

# ── Préfixe des tables (optionnel — depuis @mostajs/orm 2.3.0) ──
# Permet à plusieurs apps de cohabiter sur un même DB sans collision
# (équivalent Hibernate hibernate.physical_naming_strategy).
#
# FORTEMENT RECOMMANDÉ sur Oracle / SQL Server / SAP HANA :
# sur ces dialectes, le schéma SQL est lié au user de connexion.
# Plusieurs apps avec le même user partagent donc les mêmes tables
# (users, roles, permissions, …) — conflits silencieux garantis.
# Avec un préfixe, chaque app a son namespace : `mp_users`, `mp_roles`, …
#
# Optionnel sur SQLite/Postgres/MySQL (DB dédiée par défaut), mais
# recommandé pour cohérence dev local ↔ prod mutualisée.
#
# DB_TABLE_PREFIX=mp_

# ── Mode NET (optionnel — @mostajs/data-plug) ──────────────────
# Si défini, l'app bascule en mode NET : aucune connexion DB locale.
# Toutes les requêtes ORM passent par ce serveur distant.
# MOSTA_NET_URL=https://api.example.com/dataplug
# MOSTA_NET_APIKEY=msk_live_xxxxxxxxxxxxxxx

# ── Authentification — NextAuth v5 ─────────────────────────────
# Générer : openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-32-bytes-base64-random
AUTH_SECRET=replace-with-32-bytes-base64-random
NEXTAUTH_URL=http://localhost:4567

# ── Bootstrap admin — `npm run seed:admin` ─────────────────────
# Si ADMIN_PASSWORD est défini, l'admin est créé/réinitialisé avec.
# Sinon, un mot de passe aléatoire est généré et affiché en console
# une seule fois au premier seed.
ADMIN_EMAIL=admin@park.demo
# ADMIN_PASSWORD=changeMe!Strong123

# ── Logs SQL (debug ORM) ───────────────────────────────────────
# SHOW_SQL=true
# FORMAT_SQL=true
