{
  "name": "mosta-parkmanager",
  "version": "1.0.0",
  "description": "Showcase end-to-end de l'écosystème @mostajs/* — gestion d'un parc de loisirs/attractions (Next.js + Electron + ORM multi-dialecte).",
  "author": "Dr Hamid MADANI <drmdh@msn.com>",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://github.com/apolocine/mosta-parkmanager",
  "repository": {
    "type": "git",
    "url": "https://github.com/apolocine/mosta-parkmanager.git"
  },
  "keywords": [
    "mostajs",
    "showcase",
    "park-manager",
    "access-control",
    "next.js",
    "electron",
    "orm-multi-dialect"
  ],
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4567 -H 0.0.0.0",
