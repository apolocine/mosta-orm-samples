    "build": "next build",
    "start": "next start -p 4567",
    "lint": "eslint",
    "seed": "tsx --env-file=.env.local seeds/index.ts",
    "seed:admin": "tsx --env-file=.env.local seeds/00_admin/seed-admin.ts",
    "seed:roles": "tsx --env-file=.env.local seeds/02_roles/seed-roles.ts",
    "seed:activities": "tsx --env-file=.env.local seeds/03_activities/seed-activities.ts",
    "seed:demo": "tsx --env-file=.env.local seeds/04_demo/seed-demo.ts"
  },
